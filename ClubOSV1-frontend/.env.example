# ======================
# CedarwoodOS Frontend
# ======================
# Copy this file to .env.local and fill in your values
# NEVER commit the actual .env.local file to git

# ============================================
# CORE CONFIGURATION
# ============================================
# Backend API URL (your CedarwoodOS backend server)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Development port (frontend runs on this port)
PORT=3000

# Environment (development, staging, production)
NODE_ENV=development

# ============================================
# AUTHENTICATION
# ============================================
# Session timeout in milliseconds (default: 30 minutes)
NEXT_PUBLIC_AUTH_TIMEOUT=1800000

# ============================================
# BRANDING & THEMING
# ============================================
# Brand colors (hex values)
NEXT_PUBLIC_BRAND_PRIMARY=#0B3D3A
NEXT_PUBLIC_BRAND_PRIMARY_HOVER=#084a45

# ============================================
# EXTERNAL SERVICE URLS (Optional)
# ============================================
# Google Drive for documents
# NEXT_PUBLIC_GOOGLE_DRIVE_URL=https://drive.google.com/drive/folders/your-folder-id

# ============================================
# DEBUGGING FLAGS
# ============================================
NEXT_PUBLIC_DEBUG_API=false
NEXT_PUBLIC_DEBUG_AUTH=false

# ============================================
# PUSH NOTIFICATIONS (Optional)
# ============================================
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ============================================
# NOTES FOR DEVELOPERS
# ============================================
# 1. All frontend env vars must start with NEXT_PUBLIC_ to be available in the browser
# 2. Use .env.local for local development (git ignored)
# 3. Never expose sensitive keys (use backend proxy for secrets)
# 4. Update this file when adding new environment variables
